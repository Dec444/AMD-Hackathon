# --- Fireworks AI (required for all AI features) ---
# Get a key at https://fireworks.ai — used for menu extraction, translation, and dish visuals.
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Models — run `npm run check:fireworks` to discover which models YOUR account
# can use; it prints ready-to-paste lines for the three settings below.
# FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
# FIREWORKS_TEXT_MODEL=accounts/fireworks/models/gpt-oss-120b
# FIREWORKS_IMAGE_MODEL=accounts/fireworks/models/flux-1-schnell-fp8
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# --- Visual provider: fireworks | qwen | auto (default auto) ---
# auto tries Fireworks FLUX first and falls back to Qwen if configured.
# VISUAL_PROVIDER=auto

# --- Qwen / DashScope image generation (optional fallback) ---
# QWEN_API_KEY=your_dashscope_key_here
# QWEN_IMAGE_MODEL=qwen-image-2.0
# QWEN_IMAGE_ENDPOINT=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# VISUAL_IMAGE_SIZE=1024*1024

# --- Visual generation tuning (optional) ---
# VISUALS_MAX_AI_IMAGES=8
# VISUALS_CONCURRENCY=2
# VISUALS_ITEM_TIMEOUT_MS=28000
# VISUALS_ROUTE_BUDGET_MS=90000
# VISUAL_CACHE_MAX=400

# --- Server ---
# PORT=3000
